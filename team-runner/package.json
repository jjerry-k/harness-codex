{
  "name": "team-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "team-runner": "./bin/team-runner.js"
  },
  "scripts": {
    "validate": "node ./bin/team-runner.js validate ./examples/web-feature-team.json",
    "validate:yaml": "node ./bin/team-runner.js validate ./examples/web-feature-team.yaml",
    "plan": "node ./bin/team-runner.js plan ./examples/web-feature-team.json",
    "plan:yaml": "node ./bin/team-runner.js plan ./examples/web-feature-team.yaml",
    "run": "node ./bin/team-runner.js run ./examples/web-feature-team.json",
    "run:yaml": "node ./bin/team-runner.js run ./examples/web-feature-team.yaml"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  }
}
